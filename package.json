{
  "name": "gaato-net",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3",
    "node": ">=20"
  },
  "scripts": {
    "clean": "node scripts/clean-dist.mjs",
    "build:wasm": "moon build --target wasm-gc --release src/background",
    "build:site": "eleventy --config=eleventy.config.js",
    "build:js": "bun build main.ts --target=browser --format=esm --minify --outfile=dist/assets/main.js",
    "copy:wasm": "node scripts/copy-wasm.mjs",
    "check:moon": "moon check --target wasm-gc src/background",
    "check:rules": "moon check --target native src/rule_scan",
    "score:rules": "moon run --target native --release src/rule_scan",
    "check:toolchain": "node scripts/check-toolchain.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "bun run build && node scripts/serve-dist.mjs 4173",
    "preview": "node scripts/serve-dist.mjs 4173",
    "build": "bun run clean && bun run build:wasm && bun run build:site && bun run build:js && bun run copy:wasm",
    "validate:html": "node scripts/validate-html.mjs",
    "check:a11y": "pa11y-ci http://127.0.0.1:4173/ http://127.0.0.1:4173/ja/ http://127.0.0.1:4173/en/ http://127.0.0.1:4173/id/ http://127.0.0.1:4173/ja/posts/",
    "check:size": "node scripts/check-size.mjs",
    "check": "bun run check:toolchain && bun run typecheck && bun run check:moon && bun run check:rules && bun run build && bun run validate:html && bun run check:size",
    "deploy": "wrangler pages deploy dist --project-name=gaato-net"
  },
  "devDependencies": {
    "@11ty/eleventy": "3.1.5",
    "pa11y-ci": "4.1.0",
    "typescript": "6.0.3",
    "wrangler": "4.85.0",
    "vnu-jar": "26.4.16"
  },
  "trustedDependencies": [
    "esbuild",
    "puppeteer",
    "sharp",
    "workerd",
    "vnu-jar"
  ]
}
