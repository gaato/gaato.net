fn interest_label(lang : Lang, interest : Interest) -> String {
  match lang {
    Ja =>
      match interest {
        Linux => "Linux"
        Oss => "OSS"
        Hololive => "hololive"
        Language => "language"
      }
    En =>
      match interest {
        Linux => "Linux"
        Oss => "OSS"
        Hololive => "hololive"
        Language => "language"
      }
    Id =>
      match interest {
        Linux => "Linux"
        Oss => "OSS"
        Hololive => "hololive"
        Language => "language"
      }
  }
}

