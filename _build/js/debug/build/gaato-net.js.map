enum Lang {
  Ja
  En
  Id
} derive(Eq)

enum Interest {
  Linux
  Oss
  Hololive
  Language
} derive(Eq)

fn Lang::to_string(self : Lang) -> String {
  match self {
    Ja => "ja"
    En => "en"
    Id => "id"
  }
}

