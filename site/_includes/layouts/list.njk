---
layout: layouts/base.njk
---
<article class="content post-list" aria-labelledby="list-title">
  <header class="hero">
    <h1 id="list-title">{{ title }}</h1>
    <p class="summary">{{ description }}</p>
  </header>

  {%- if posts.length %}
  <ol class="entries">
    {%- for post in posts %}
    <li>
      <article>
        <p class="post-meta">
          <time datetime="{{ post.date | htmlDate }}">{{ post.date | readableDate(lang) }}</time>
          <a href="/{{ lang }}/posts/categories/{{ post.data.category }}/">{{ site.categories[post.data.category][lang] }}</a>
        </p>
        <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
        <p>{{ post.data.description }}</p>
      </article>
    </li>
    {%- endfor %}
  </ol>
  {%- else %}
  <p class="summary">{{ emptyMessage }}</p>
  {%- endif %}
</article>
